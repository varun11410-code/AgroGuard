# =============================================================================
# AgroGuard Backend — Environment Variables Template
# =============================================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every blank value in .env
#   3. NEVER commit .env to Git — it is listed in .gitignore
# =============================================================================

# ----------------------------------------------------------------------------
# Flask Runtime
# ----------------------------------------------------------------------------
# Environment: development | testing | production
FLASK_ENV=development

# Set to 1 to enable the interactive debugger and auto-reloader
FLASK_DEBUG=1

# Port the dev server listens on (default: 5001)
PORT=5001

# A random secret string used for session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# ----------------------------------------------------------------------------
# Database (Supabase PostgreSQL)
# ----------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Leave blank in development to use the SQLite fallback (sqlite:///agroguard_dev.db)
DATABASE_URL=postgresql://username:password@host:5432/database

# ----------------------------------------------------------------------------
# Authentication (JWT)
# ----------------------------------------------------------------------------
# A random secret string used to sign JWT tokens (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=

# ----------------------------------------------------------------------------
# AI (Google Gemini)
# ----------------------------------------------------------------------------
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ----------------------------------------------------------------------------
# Storage (Cloudinary)
# ----------------------------------------------------------------------------
# Obtain from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=